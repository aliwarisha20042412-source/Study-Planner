<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA Compatible" content="IE=edge">
  <meta name="viewport" content="width=device=width, initial-scale=1.0">
  <title>Stopwatch</title>
 </head>
 <body>
 
  <div class="containter">
    <h1>Stopwatch</h1>
    <p class="time">
      <span id="minutes">00</span>:<span id="seconds">00</span>:<span id="tens">00</span>
    </p>  
    <button id="Start">Start</button>
    <button id="Stop">Stop</button>
    <button id="Reset">Reset</button>
  </div>  
</body>   
<script> 
  window.onload = function(){
  let minutes = 0;
  let seconds = 0;
  let tens = 0;  
  let appendMinutes = document.querySelector('#Minutes')
  let appendSeconds = document.querySelector('#Seconds')
  let appendTens = document.querySelector('#Tens')

  let startBtn = document.querySelector('#Start')
  let stopBtn = document.querySelector('#Stop')
  let resetBtn = document.querySelector('#Reset')
  let Interval;


  const startTimer = () => {
      tens++
      if (tens <= 9){
          appendTens.innterHTML = '0' + tens
      }
      if (tens > 9) {
          appendTens.innterHTML = tens
      }
      if (tens > 99) {
        seconds ++
        appendSeconds.innterHTML = '0' + seconds;
        tens = 0;
        appendTens.innterHTML = '0' + 0;
      }

      if (seconds > 59) {
        minutes++
        appendMinutes.innterHTML = '0' + minutes
        seconds = 0
        appendSeconds.innerHTML = '0' + 0;
      }

  };

  startBtn.onclick = () => {
      clearInterval(Interval)
      Interval = setInterval(startTimer, 10);
  };

  stopBtn.onclick = () => {
    clearInterval(Interval)
  };
  resetBtn.onclick = () => {
    clearInterval(Interval)
    tens = '00'
    seconds = '00'
    minutes = '00'
    appendTens.innterHTML = tens;
    appendSeconds.innerHTML = seconds;
    appendMinutes.innerHTML = minutes;
  };

  };
</script>
</html>